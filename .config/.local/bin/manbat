#!/usr/bin/env bash
# set -euo pipefail

COMMAND1="$1"
COMMAND2="$2"
MANEXC=$(man $COMMAND1)

# :h nobuflisted (don't put it in the buflist)
# :h nofile	 will not be written; beacuse you can quit without using "!"
#
if [[ $MANEXC ]]; then 
	man $COMMAND1 | nvim +'setlocal nobuflisted' +'setlocal buftype=nofile'	
else
	echo $MANEXC
fi
